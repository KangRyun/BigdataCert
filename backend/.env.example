CONTENT_DIR=../content
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# DB — 로컬은 SQLite. 배포 시 PostgreSQL 등으로.
DATABASE_URL=sqlite:///./dev.db

# JWT — 배포 시 반드시 강한 랜덤값으로 교체. 예: python -c "import secrets; print(secrets.token_urlsafe(64))"
# NextAuth 와 같은 값을 공유 (HS256). 동일한 비밀로 백엔드가 NextAuth 발급 토큰을 검증 가능.
JWT_SECRET=change-me-in-production-use-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_DAYS=7

# Google OAuth — frontend 가 받은 ID token 의 audience 비교용. Google Cloud Console 의 Web Client ID.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
