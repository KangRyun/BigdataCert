# 클라이언트에서 fetch 시 사용 (브라우저 노출)
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Server Component / NextAuth 에서 사용 (SSR, 비공개)
API_BASE_URL=http://localhost:8000

# NextAuth v5 (= Auth.js v5)
# AUTH_SECRET 은 백엔드의 JWT_SECRET 과 동일해야 백엔드 토큰을 NextAuth 가 검증 가능
# 생성: openssl rand -base64 32
AUTH_SECRET=use-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Google OAuth — Google Cloud Console → Credentials → OAuth client ID (Web application)
AUTH_GOOGLE_ID=your-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-client-secret

# Google 버튼 노출 토글 (선택)
NEXT_PUBLIC_GOOGLE_ENABLED=1
